<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- 應用程式設定 -->
    <add key="ApplicationPath" value="C:\Users\BaoGo\Documents\ClaudeCode_Project\SQA_AI_Automation\demo\shopping_cart\ShoppingCartWebViewHost\bin\Release\net8.0-windows\ShoppingCartWebViewHost.exe" />
    <add key="ApplicationUrl" value="http://localhost:8888" />
    <add key="AutoStartDemoServer" value="true" />
    <add key="DemoServerScript" value="" />
    
    <!-- 瀏覽器設定（如果使用 Web 應用） -->
    <add key="BrowserType" value="Edge" />
    
    <!-- 超時設定（毫秒） -->
    <add key="DefaultTimeout" value="10000" />
    <add key="ElementTimeout" value="5000" />
    
    <!-- 截圖設定 -->
    <add key="TakeScreenshotOnFailure" value="true" />
    <add key="ScreenshotDirectory" value="Screenshots" />
    <add key="WriteFailureLogOnFailure" value="true" />
    <add key="FailureLogDirectory" value="FailureLogs" />
    
    <!-- 測試設定 -->
    <add key="MaxRetryCount" value="3" />
    <add key="RetryDelay" value="1000" />
  </appSettings>
</configuration>
