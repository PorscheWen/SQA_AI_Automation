<?xml version="1.0" encoding="UTF-8"?>
<!-- 瀏覽器顯示請用 操作app說明書.html；本 XML 為結構化原始檔 -->
<AppManual app="Semi Inspection Desktop" version="2.1" lang="zh-TW" updated="2026-06-05">
  <Title>Semi Inspection Desktop 操作說明書</Title>
  <Subtitle>半導體 AOI Recipe、RawData 與 Defect Chart</Subtitle>

  <Section id="overview" title="概述">
    <Paragraph>工作區根目錄：<Path>Recipe_data</Path></Paragraph>
    <Paragraph>流程：Import Recipe → RawData → Defect Chart → Run Inspection</Paragraph>
  </Section>

  <Section id="quickstart" title="快速開始">
    <Step order="1"><Name>建置</Name><Command>build_semi.bat</Command></Step>
    <Step order="2"><Name>啟動</Name><Command>run_semi.bat</Command></Step>
    <Step order="3"><Name>載入 Recipe</Name><Command>Import Recipe（Ctrl+I）</Command></Step>
    <Step order="4"><Name>分析</Name><Command>RawData → Defect Chart → Run Inspection</Command></Step>
  </Section>

  <Section id="menu-tools" title="Tools 選單">
    <MenuItem name="Import Recipe" shortcut="Ctrl+I" detail="匯入 JSON Recipe" />
    <MenuItem name="RawData" shortcut="Ctrl+E" detail="Inspection Raw Data 參數表" />
    <MenuItem name="Defect Chart" shortcut="Ctrl+D" detail="DefectSummary 曲線圖" />
    <MenuItem name="Run Inspection" shortcut="Ctrl+R" detail="模擬 AOI 檢測 log" />
    <MenuItem name="About..." shortcut="" detail="功能說明" />
  </Section>

  <Section id="toolbar" title="工具列">
    <Toolbar name="Toolbar0">
      <Button name="Import Recipe" automationId="btnImportRecipe" shortcut="Ctrl+I" icon="wafer+recipe" />
      <Button name="Run Inspection" automationId="btnRunInspection" shortcut="Ctrl+R" icon="scan+play" />
      <Button name="About" automationId="btnToolbar0About" icon="info" />
    </Toolbar>
    <Toolbar name="Toolbar1">
      <Button name="RawData" automationId="btnParameters" shortcut="Ctrl+E" icon="raw-table" />
      <Button name="Defect Chart" automationId="btnDefectChart" shortcut="Ctrl+D" icon="wafer+chart" />
    </Toolbar>
  </Section>

  <Section id="workspace" title="工作區">
    <Control name="treeFiles" detail="File Tree" />
    <Control name="dataGridParameters" detail="RawData 參數表" />
    <Control name="pictureBoxChart" detail="Defect Chart" />
    <Control name="txtToolLog" detail="日誌區" />
  </Section>

  <Section id="recipe-data" title="Recipe_data">
    <File name="InspectionRecipe_Sample.json" purpose="AOI Recipe 樣本（5 類 DefectSummary）" />
    <File name="_invalid_sample.txt" purpose="TC07 負向測試" />
  </Section>

  <Section id="test-cases" title="測試案例">
    <Path>Automation_testcase\Test_cases\TEST_PLAN.md</Path>
    <Path>Automation_testcase\Test_cases\SemiInspection_10_TestCases.md</Path>
  </Section>
</AppManual>
