<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- 應用程式設定 -->
    <add key="ApplicationPath" value="C:\Path\To\ShoppingCart\index.html" />
    <add key="ApplicationUrl" value="http://localhost:8080" />
    
    <!-- 瀏覽器設定（如果使用 Web 應用） -->
    <add key="BrowserType" value="Chrome" />
    
    <!-- 超時設定（毫秒） -->
    <add key="DefaultTimeout" value="10000" />
    <add key="ElementTimeout" value="5000" />
    
    <!-- 截圖設定 -->
    <add key="TakeScreenshotOnFailure" value="true" />
    <add key="ScreenshotDirectory" value="Screenshots" />
    
    <!-- 測試設定 -->
    <add key="MaxRetryCount" value="3" />
    <add key="RetryDelay" value="1000" />
  </appSettings>
</configuration>
